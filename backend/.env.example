# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
# In production (Railway), DATABASE_URL is auto-injected — leave the DB_* vars unset.
# Locally, use the DB_* vars below.
# DATABASE_URL=postgres://user:pass@host:port/dbname

DB_HOST=localhost
DB_PORT=5432
DB_NAME=clubhouse_stakes
DB_USER=postgres
DB_PASSWORD=your_password

# ── JWT ──────────────────────────────────────────────────────
# In production, generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Leave unset in development to allow all origins.
# CORS_ORIGINS=https://www.clubhousestakes.com,https://clubhousestakes.com

# ── golfcourseapi.com (course + hole data) ──────────────────
# Sign up at https://golfcourseapi.com to get a key.
GOLFCOURSE_API_KEY=

# ── Email (clubhouse invites etc.) ──────────────────────────
# Use any SMTP provider (SendGrid, Mailgun, AWS SES, Gmail).
# When unset the backend logs invites to the console instead of sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Clubhouse Stakes <no-reply@clubhousestakes.com>"
# Public app URL — used in invite emails so recipients know where to sign up.
APP_PUBLIC_URL=https://clubhousestakes.com

# ── Stripe (not yet wired up) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── File uploads ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
